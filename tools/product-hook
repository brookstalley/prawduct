def main() -> int:
    if len(sys.argv) < 2:
        print("Usage: product-hook {clear|stop}", file=sys.stderr)
        return 1

    command = sys.argv[1]
    project_dir = get_project_dir()

    if command == "clear":
        return cmd_clear(project_dir)
    elif command == "stop":
        return cmd_stop(project_dir)
    else:
        print("Usage: product-hook {clear|stop}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
