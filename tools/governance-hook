#!/usr/bin/env bash
#
# governance-hook — Single entry point for all Claude Code governance hooks.
#
# Resolves framework root from this script's location and delegates to the
# Python governance module. All subcommands (gate, track, failure, stop,
# commit, prompt, compact-reinject) are handled by tools/governance/__main__.py.
#
# Usage (in .claude/settings.json):
#   "$CLAUDE_PROJECT_DIR/tools/governance-hook" gate
#   "$FW/tools/governance-hook" stop

FW_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Export CCPID so the Python governance module can read it from os.environ.
# CCPID is set by hook commands in settings.json as CCPID=$PPID, where $PPID
# is Claude Code's PID — stable across all hook invocations for one session.
export CCPID="${CCPID:-}"

# Timing instrumentation: log elapsed time per hook invocation
_START_NS=$(python3 -c "import time; print(int(time.time_ns()))" 2>/dev/null || echo "")

PYTHONPATH="$FW_ROOT/tools" python3 -m governance "$@" --root "$FW_ROOT"
_EXIT=$?

if [[ -n "$_START_NS" ]]; then
    _END_NS=$(python3 -c "import time; print(int(time.time_ns()))" 2>/dev/null || echo "")
    if [[ -n "$_END_NS" ]]; then
        _ELAPSED_MS=$(python3 -c "print(($_END_NS - $_START_NS) // 1000000)" 2>/dev/null || echo "")
        _CMD="${1:-unknown}"
        _LOG="${CLAUDE_PROJECT_DIR:-.}/.prawduct/.hook-timing.log"
        if [[ -n "$_ELAPSED_MS" ]]; then
            echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) $_CMD ${_ELAPSED_MS}ms" >> "$_LOG" 2>/dev/null || true
        fi
    fi
fi

exit $_EXIT
